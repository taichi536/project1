# ============================================================
# 自動スカウト送信システム 設定ファイル
# このファイルを .env にコピーして値を設定してください。
# ============================================================

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# 使用モデル（haiku が高速・低コストでおすすめ）
CLAUDE_MODEL=claude-haiku-4-5-20251001

# データベースパス
DB_PATH=data/scouts.db

# スケジュール実行間隔（分）
SCHEDULE_INTERVAL_MINUTES=60

# テンプレートディレクトリ
TEMPLATES_DIR=templates

# ブラウザ設定
HEADLESS=true          # false にすると画面を表示（デバッグ用）
SLOW_MO_MS=800         # ブラウザ操作間の待機時間（ms）

# ============================================================
# doda
# TAG_POSITION_MAP: "タグ名:テンプレートファイル名,..." の形式
# 例: "バックエンドエンジニア:backend_engineer,PMポジション:product_manager"
# ============================================================
DODA_ENABLED=false
DODA_EMAIL=your-email@example.com
DODA_PASSWORD=your-password
DODA_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
DODA_MAX_SCOUTS_PER_RUN=30

# ============================================================
# ビズリーチ
# ============================================================
BIZREACH_ENABLED=false
BIZREACH_EMAIL=your-email@example.com
BIZREACH_PASSWORD=your-password
BIZREACH_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
BIZREACH_MAX_SCOUTS_PER_RUN=30

# ============================================================
# マイナビ転職
# ============================================================
MYNAVI_ENABLED=false
MYNAVI_EMAIL=your-email@example.com
MYNAVI_PASSWORD=your-password
MYNAVI_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
MYNAVI_MAX_SCOUTS_PER_RUN=30

# ============================================================
# Green
# ============================================================
GREEN_ENABLED=false
GREEN_EMAIL=your-email@example.com
GREEN_PASSWORD=your-password
GREEN_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
GREEN_MAX_SCOUTS_PER_RUN=30

# ============================================================
# AMBI
# ============================================================
AMBI_ENABLED=false
AMBI_EMAIL=your-email@example.com
AMBI_PASSWORD=your-password
AMBI_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
AMBI_MAX_SCOUTS_PER_RUN=30

# ============================================================
# dodaX
# ============================================================
DODAX_ENABLED=false
DODAX_EMAIL=your-email@example.com
DODAX_PASSWORD=your-password
DODAX_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
DODAX_MAX_SCOUTS_PER_RUN=30

# ============================================================
# リクルートダイレクトスカウト
# ============================================================
RECRUIT_DIRECT_ENABLED=false
RECRUIT_DIRECT_EMAIL=your-email@example.com
RECRUIT_DIRECT_PASSWORD=your-password
RECRUIT_DIRECT_TAG_POSITION_MAP=バックエンドエンジニア:backend_engineer
RECRUIT_DIRECT_MAX_SCOUTS_PER_RUN=30
