{
  "manifest_version": 3,
  "name": "Snow-we スカウト パーソナライズ生成",
  "version": "1.18.161",
  "description": "候補者プロフィールからパーソナライズ文を1〜2文で自動生成します",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "clipboardWrite",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://raw.githubusercontent.com/*",
    "https://api.anthropic.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://docs.google.com/*",
    "https://bizreach.biz/*",
    "https://www.bizreach.biz/*",
    "https://*.bizreach.biz/*",
    "https://es-support.jp/*",
    "https://doda-x.jp/*",
    "https://x.doda.jp/*",
    "https://search.doda-x.jp/*",
    "https://ambi.jp/*",
    "https://en-ambi.com/*",
    "https://www.green-japan.com/*",
    "https://mynavi-agent.jp/*",
    "https://www.mynavi-agent.jp/*",
    "https://agent.mynavi.jp/*",
    "https://rds.recruitdirect.jp/*",
    "https://ats.hrtech.rikunabi.com/*",
    "https://*.rikunabi.com/*",
    "https://*.hrtech.jp/*",
    "https://*.hrtech.rikunabi.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "パーソナライズ文を生成"
  },
  "content_scripts": [
    {
      "matches": [
        "https://bizreach.biz/*",
        "https://www.bizreach.biz/*",
        "https://*.bizreach.biz/*",
        "https://es-support.jp/*",
        "https://doda-x.jp/*",
        "https://x.doda.jp/*",
        "https://search.doda-x.jp/*",
        "https://ambi.jp/*",
        "https://en-ambi.com/*",
        "https://www.green-japan.com/*",
        "https://mynavi-agent.jp/*",
        "https://www.mynavi-agent.jp/*",
        "https://agent.mynavi.jp/*",
        "https://rds.recruitdirect.jp/*",
        "https://ats.hrtech.rikunabi.com/*",
        "https://*.rikunabi.com/*",
        "https://*.hrtech.jp/*",
        "https://*.hrtech.rikunabi.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
